# =============================================================================
# ROGER — Variables de entorno para PRODUCCIÓN
# Usado por docker-compose.prod.yml. Copiar a .env.prod y completar.
#
#   cp .env.prod.example .env.prod
#
# Generar SECRET_KEY:      openssl rand -hex 32
# Generar REDIS_PASSWORD:  openssl rand -base64 24
# Generar QDRANT_API_KEY:  openssl rand -base64 32
#
# Convive con .env (dev). NUNCA commitear este archivo con valores reales.
# =============================================================================

# ─── Seguridad ────────────────────────────────────────────────────────────────
SECRET_KEY=CAMBIAR_ejecutar_openssl_rand_hex_32

# ─── Base de datos relacional ─────────────────────────────────────────────────
# SQLite por decisión del proyecto. El path /app/data/valeria.db apunta al
# volumen ./data del host (ver docker-compose.prod.yml). Para migrar a Postgres
# en el futuro: cambiar a postgresql+asyncpg://user:pass@postgres:5432/roger
DATABASE_URL=sqlite+aiosqlite:////app/data/valeria.db

# ─── Uvicorn (backend) ────────────────────────────────────────────────────────
# Workers: regla clásica (cores * 2 + 1). Para una VM de 4 cores → 4-9.
UVICORN_WORKERS=4

# ─── Redis (cache + rate limiting) ────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_ejecutar_openssl_rand_base64_24

# ─── Vector store ─────────────────────────────────────────────────────────────
# Default en prod: qdrant. Para volver a chroma (no recomendado) → chroma.
# El servicio qdrant del compose es el que sirve los embeddings.
VECTOR_STORE_PROVIDER=qdrant
QDRANT_API_KEY=CAMBIAR_ejecutar_openssl_rand_base64_32

# ─── LLM (proveedor de IA) ────────────────────────────────────────────────────
# Opciones: groq | openai | anthropic | openai_compatible
LLM_PROVIDER=groq
GROQ_API_KEY=CAMBIAR_tu_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Alternativas (descomentar la deseada, comentar las groq de arriba):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Correo UCN ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=CAMBIAR_usuario@ucn.cl
SMTP_PASSWORD=CAMBIAR_contrasena_correo
SMTP_FROM=CAMBIAR_usuario@ucn.cl

# ─── URL pública y CORS ───────────────────────────────────────────────────────
# Mientras TI UCN no asigne dominio, usar https://<IP_pública>.
FRONTEND_URL=https://CAMBIAR_DOMINIO_O_IP
CORS_ORIGINS=["https://CAMBIAR_DOMINIO_O_IP"]

# ─── TLS ──────────────────────────────────────────────────────────────────────
# Path en el host donde están fullchain.pem + privkey.pem (montado read-only).
TLS_CERT_DIR=/etc/roger/certs

# ─── Analizadores de taxonomía ────────────────────────────────────────────────
# stub (default — sin GPU): no requiere torch.
# Para activar inferencia real, instalar requirements-analyzers.txt y cambiar a
# clip / geoclip / places365 según corresponda.
ATTR02_ANALYZER=stub
ATTR03_ANALYZER=stub
ATTR04_ANALYZER=stub

# ─── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
