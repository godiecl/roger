# ===================================
# APPLICATION
# ===================================
APP_NAME="Roger: Robert Gerstmann's Repository (Valeria)"
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# ===================================
# API
# ===================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# ===================================
# DATABASE
# ===================================
DATABASE_URL=sqlite+aiosqlite:///./valeria.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/roger

# ===================================
# AUTHENTICATION
# ===================================
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================================
# TAXONOMY ANALYZERS — PROVEEDORES AGNÓSTICOS
# Cambia el valor para activar el analizador real sin tocar código.
# Atributo 02 — Datación cronológica: stub (default, sin deps) | clip (open-clip-torch torch)
# Atributo 03 — Referencia geográfica: stub (default, sin deps) | geoclip (geoclip torch)
# Atributo 04 — Contexto ambiental:    stub (default, sin deps) | places365 (torch torchvision)
# ===================================
ATTR02_ANALYZER=stub
ATTR03_ANALYZER=stub
ATTR04_ANALYZER=stub

# ===================================
# LLM — PROVEEDOR AGNÓSTICO
# Cambia solo LLM_PROVIDER para cambiar de proveedor sin tocar código.
# Opciones: groq | openai | anthropic | openai_compatible | together | mistral | perplexity
# ===================================
LLM_PROVIDER=groq
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
# Para proveedores genéricos OpenAI-compatibles (Together, Mistral, Perplexity, etc.)
# LLM_API_KEY=tu-api-key
# LLM_MODEL=nombre-del-modelo
# LLM_BASE_URL=https://api.proveedor.com/v1

# ===================================
# OPENAI
# ===================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# ===================================
# ANTHROPIC (optional)
# ===================================
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ===================================
# VECTOR DATABASE
# ===================================
CHROMA_PERSIST_DIRECTORY=./chroma_db
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ===================================
# CACHE
# ===================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ===================================
# STORAGE
# ===================================
STORAGE_TYPE=local
STORAGE_PATH=./storage/images
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=roger-images

# ===================================
# RATE LIMITING
# ===================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# ===================================
# SMTP — Correo UCN (Office 365)
# ===================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=diego.leon@alumnos.ucn.cl
SMTP_PASSWORD=contrasena
SMTP_FROM=diego.leon@alumnos.ucn.cl
SMTP_FROM_NAME=Archivo ROGER
FRONTEND_URL=http://localhost:5173

# ===================================
# LOGGING
# ===================================
LOG_LEVEL=INFO
LOG_FORMAT=json
