# Copiar este archivo como .env y completar los valores antes de hacer deploy.
# cp .env.example .env

# OBLIGATORIO — cambiar por un valor largo y aleatorio
SECRET_KEY=cambiar-esto-por-un-valor-secreto-largo

# Base de datos (por defecto SQLite, para producción usar PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:////app/data/valeria.db
# DATABASE_URL=postgresql+asyncpg://usuario:contraseña@host:5432/roger

# LLM — proveedor para narrativas y chat con IA
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...

# Correo UCN
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=tu-correo@ucn.cl
SMTP_PASSWORD=tu-contraseña
SMTP_FROM=tu-correo@ucn.cl

# URL pública del servidor (para links en correos)
FRONTEND_URL=http://IP-O-DOMINIO-DEL-SERVIDOR

# Analizadores de taxonomía (attr 02, 03, 04)
# Valores disponibles:
#   stub     — sin ML, modo desarrollo (por defecto)
#   groq     — Groq Vision llama-4-scout (RECOMENDADO, requiere GROQ_API_KEY)
#   clip     — CLIP zero-shot (solo attr 02, requiere torch + open_clip)
#   geoclip  — GeoCLIP (solo attr 03, requiere torch + geoclip)
#   places365— Places365 (solo attr 04, requiere torch + torchvision)
# Para modelos locales instalar: pip install -r valeria/requirements-analyzers.txt
ATTR02_ANALYZER=groq
ATTR03_ANALYZER=groq
ATTR04_ANALYZER=groq
