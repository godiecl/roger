# =============================================================================
# ROGER — Variables de entorno para producción
# Copiar este archivo a .env y completar los valores marcados con CAMBIAR
#
#   cp .env.example .env
#
# Generar SECRET_KEY:      openssl rand -hex 32
# Generar REDIS_PASSWORD:  openssl rand -base64 24
# =============================================================================

# ─── Seguridad ────────────────────────────────────────────────────────────────
SECRET_KEY=CAMBIAR_ejecutar_openssl_rand_hex_32

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////app/data/valeria.db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CAMBIAR_ejecutar_openssl_rand_base64_24

# ─── LLM (proveedor de IA) ────────────────────────────────────────────────────
# Opciones: groq | openai | anthropic
LLM_PROVIDER=groq
GROQ_API_KEY=CAMBIAR_tu_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (alternativa — descomentar y comentar las líneas groq)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── Correo UCN ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=CAMBIAR_usuario@ucn.cl
SMTP_PASSWORD=CAMBIAR_contrasena_correo
SMTP_FROM=CAMBIAR_usuario@ucn.cl

# ─── URL pública ──────────────────────────────────────────────────────────────
# Usar la IP del servidor hasta que TI UCN asigne dominio
FRONTEND_URL=http://CAMBIAR_IP_DEL_SERVIDOR

# ─── TLS — completar cuando TI UCN entregue dominio y certificado ─────────────
# TLS_CERT_DIR=/etc/roger/certs

# ─── Analizadores de taxonomía ────────────────────────────────────────────────
# stub: sin ML (por defecto, sin dependencias pesadas)
# groq: Groq Vision llama-4-scout (requiere GROQ_API_KEY)
# clip: CLIP zero-shot (solo attr02, requiere torch + open_clip)
# geoclip: GeoCLIP (solo attr03, requiere torch + geoclip)
# places365: Places365 (solo attr04, requiere torch + torchvision)
ATTR02_ANALYZER=stub
ATTR03_ANALYZER=stub
ATTR04_ANALYZER=stub

# ─── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
